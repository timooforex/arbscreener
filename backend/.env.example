# ── SERVER ──────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MONGODB ─────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/arbscreener?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ── ADMIN ───────────────────────────────────────────
# Only this email gets admin access on login
ADMIN_EMAIL=your@email.com

# ── PAYSTACK ────────────────────────────────────────
# Get from dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_live_your_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_key_here

# ── USDT PAYMENTS ───────────────────────────────────
# Master USDT wallet — you receive all payments here
# Each user gets a unique sub-address derived from their ID
USDT_MASTER_WALLET=TYourTRC20WalletAddressHere
USDT_NETWORK=TRC20

# ── PLANS (monthly prices in USD) ───────────────────
STARTER_MONTHLY_PRICE=9.99
STARTER_YEARLY_PRICE=79.99
PRO_MONTHLY_PRICE=24.99
PRO_YEARLY_PRICE=199.99

# ── FRONTEND URL ────────────────────────────────────
FRONTEND_URL=https://your-site.railway.app
